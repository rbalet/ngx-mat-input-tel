{
  "name": "ngx-mat-input-tel",
  "version": "21.2.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build ngx-mat-input-tel --configuration production",
    "test": "ng test ngx-mat-input-tel --watch=false",
    "test:ci": "ng test ngx-mat-input-tel --watch=false --coverage",
    "lint": "ng lint",
    "publish": "ng build ngx-mat-input-tel --configuration production && npm run copy-files && npm publish ./dist/ngx-mat-input-tel",
    "copy-files": "cp README.md dist/ngx-mat-input-tel && cp LICENSE dist/ngx-mat-input-tel",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.0",
    "@angular/cdk": "21.2.0",
    "@angular/common": "21.2.0",
    "@angular/compiler": "21.2.0",
    "@angular/core": "21.2.0",
    "@angular/forms": "21.2.0",
    "@angular/material": "21.2.0",
    "@angular/platform-browser": "21.2.0",
    "@angular/platform-browser-dynamic": "21.2.0",
    "@angular/router": "21.2.0",
    "libphonenumber-js": "^1.12.38",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "21.2.0",
    "@angular-devkit/schematics": "21.2.0",
    "@angular/build": "^21.2.0",
    "@angular/cli": "21.2.0",
    "@angular/compiler-cli": "21.2.0",
    "@angular/language-service": "21.2.0",
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/jasmine": "5.1.15",
    "@types/jasminewd2": "2.0.13",
    "@types/node": "24.11.0",
    "@vitest/coverage-v8": "^4.0.18",
    "angular-eslint": "21.2.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jasmine-core": "5.13.0",
    "jasmine-spec-reporter": "7.0.0",
    "jsdom": "^28.1.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage-istanbul-reporter": "3.0.3",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "lint-staged": "16.3.1",
    "ng-packagr": "21.2.0",
    "prettier": "3.8.1",
    "semantic-release": "25.0.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.1",
    "vitest": "^4.0.18",
    "zone.js": "^0.16.1"
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.{js,css,md}": "prettier --write"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "pkgRoot": "dist/ngx-mat-input-tel",
          "access": "public"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
